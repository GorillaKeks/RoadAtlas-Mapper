<UserControl x:Class="RoadAtlas.Mapper.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

	<ScrollViewer VerticalScrollBarVisibility="Auto">

		<Grid Margin="10">

			<Grid.RowDefinitions>
				<RowDefinition Height="Auto"/>
				<RowDefinition Height="Auto"/>
				<RowDefinition Height="Auto"/>
				<RowDefinition Height="Auto"/>
				<RowDefinition Height="Auto"/>
			</Grid.RowDefinitions>

			<!-- Header -->

			<TextBlock Grid.Row="0"
                       Text="Dashboard"
                       Style="{StaticResource PageTitleStyle}"
                       Margin="0,0,0,20"/>

			<!-- Application + Quick Actions -->

			<Grid Grid.Row="1"
                  Margin="0,0,0,12">

				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="2*"/>
					<ColumnDefinition Width="1*"/>
				</Grid.ColumnDefinitions>

				<!-- Application -->

				<Border Grid.Column="0"
                        Style="{StaticResource CardStyle}"
                        Margin="0,0,12,0">

					<StackPanel>

						<TextBlock Text="Application"
                                   Style="{StaticResource SectionTitleStyle}"
                                   Margin="0,0,0,15"/>

						<TextBlock x:Name="VersionText"
                                   Margin="0,0,0,8"/>

						<TextBlock x:Name="UpdateStatusText"
                                   Margin="0,0,0,8"
                                   FontWeight="Bold"/>

						<TextBlock Text="GitHub Status"
                                   FontWeight="SemiBold"/>

						<TextBlock x:Name="GitHubStatusText"
                                   Margin="0,0,0,10"
                                   Text="Connected"/>

						<TextBlock Text="Repository Status"
                                   FontWeight="SemiBold"/>

						<TextBlock x:Name="RepositoryStatusText"
                                   Text="Connected"/>

						<Button x:Name="OpenReleasePageButton"
                                Content="Open Release Page"
                                Width="180"
                                Margin="0,15,0,0"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Visibility="Collapsed"
                                Click="OpenReleasePageButton_Click"/>

					</StackPanel>

				</Border>

				<!-- Quick Actions -->

				<Border Grid.Column="1"
                        Style="{StaticResource CardStyle}">

					<StackPanel>

						<TextBlock Text="Quick Actions"
                                   Style="{StaticResource SectionTitleStyle}"
                                   Margin="0,0,0,15"/>

						<Button x:Name="OpenOutputFolderButton"
                                Content="Open Output Folder"
                                Height="40"
                                Margin="0,0,0,10"
                                Style="{StaticResource PrimaryButtonStyle}"/>

						<Button x:Name="OpenRepositoryButton"
                                Content="Open Repository"
                                Height="40"
                                Margin="0,0,0,10"
                                Style="{StaticResource PrimaryButtonStyle}"/>

						<Button x:Name="CheckUpdatesButton"
                                Content="Check Updates"
                                Height="40"
                                Style="{StaticResource PrimaryButtonStyle}"/>

					</StackPanel>

				</Border>

			</Grid>

			<!-- Statistics -->

			<Border Grid.Row="2"
                    Style="{StaticResource CardStyle}"
                    Margin="0,0,0,12">

				<StackPanel>

					<TextBlock Text="Statistics"
                               Style="{StaticResource SectionTitleStyle}"
                               Margin="0,0,0,15"/>

					<TextBlock x:Name="ETS2PathText"
                               Margin="0,0,0,8"
                               Text="ETS2 Path"/>

					<TextBlock x:Name="ATSPathText"
                               Margin="0,0,0,8"
                               Text="ATS Path"/>

					<TextBlock x:Name="OutputFolderText"
                               Margin="0,0,0,8"
                               Text="Output Folder"/>

					<TextBlock x:Name="RepositoryText"
                               Text="Repository Status"/>

				</StackPanel>

			</Border>

			<!-- System Status -->

			<Border Grid.Row="3"
                    Style="{StaticResource CardStyle}"
                    Margin="0,0,0,12">

				<StackPanel>

					<TextBlock Text="System Status"
                               Style="{StaticResource SectionTitleStyle}"
                               Margin="0,0,0,15"/>

					<StackPanel x:Name="StatusPanel"/>

				</StackPanel>

			</Border>

			<!-- Recent Activity -->

			<Border Grid.Row="4"
                    Style="{StaticResource CardStyle}">

				<StackPanel>

					<TextBlock Text="Recent Activity"
                               Style="{StaticResource SectionTitleStyle}"
                               Margin="0,0,0,15"/>

					<TextBlock Text="Last Extraction"
                               FontWeight="SemiBold"/>

					<TextBlock x:Name="LastExtractionText"
                               Margin="0,0,0,10"
                               Text="Never"/>

					<TextBlock Text="Last Generator Run"
                               FontWeight="SemiBold"/>

					<TextBlock x:Name="LastGeneratorText"
                               Margin="0,0,0,10"
                               Text="Never"/>

					<TextBlock Text="Last Repository Sync"
                               FontWeight="SemiBold"/>

					<TextBlock x:Name="LastRepositorySyncText"
                               Margin="0,0,0,15"
                               Text="Never"/>

					<Separator Margin="0,10"/>

					<TextBlock x:Name="OverallStatusText"
                               FontSize="18"
                               FontWeight="Bold"/>

				</StackPanel>

			</Border>

		</Grid>

	</ScrollViewer>

</UserControl>