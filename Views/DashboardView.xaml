<UserControl x:Class="RoadAtlas.Mapper.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer VerticalScrollBarVisibility="Auto">

        <StackPanel Margin="10">

            <TextBlock Text="Dashboard"
                       FontSize="28"
                       FontWeight="Bold"/>

            <Separator Margin="0,10"/>

            <TextBlock Text="Application"
                       FontSize="20"
                       FontWeight="Bold"
                       Margin="0,0,0,10"/>

            <TextBlock x:Name="VersionText"
                       FontSize="14"
                       Margin="0,0,0,5"/>

            <TextBlock x:Name="UpdateStatusText"
                       FontSize="14"
                       FontWeight="Bold"
                       Margin="0,0,0,10"/>

            <Button x:Name="OpenReleasePageButton"
                    Content="Open Release Page"
                    Width="180"
                    Height="30"
                    Visibility="Collapsed"
                    Click="OpenReleasePageButton_Click"/>

            <Separator Margin="0,15"/>

            <TextBlock Text="System Status"
                       FontSize="20"
                       FontWeight="Bold"
                       Margin="0,0,0,10"/>

            <StackPanel x:Name="StatusPanel"/>

            <Separator Margin="0,15"/>

            <TextBlock x:Name="OverallStatusText"
                       FontSize="18"
                       FontWeight="Bold"/>

        </StackPanel>

    </ScrollViewer>

</UserControl>