<UserControl x:Class="ETS2LA.Mapper.Views.ExtractionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer VerticalScrollBarVisibility="Auto">

        <StackPanel Margin="20">

            <TextBlock Text="ETS2LA Map Extraction"
                       FontSize="28"
                       FontWeight="Bold"/>

            <Separator Margin="0,10,0,20"/>

            <TextBlock Text="Game"/>

            <ComboBox x:Name="GameComboBox"
                      Margin="0,5,0,15"
                      SelectedIndex="1"
                      SelectionChanged="GameComboBox_SelectionChanged">

                <ComboBoxItem Content="Euro Truck Simulator 2"/>
                <ComboBoxItem Content="American Truck Simulator"/>

            </ComboBox>

            <TextBlock Text="Game Path"/>

            <TextBox x:Name="GamePathTextBox"
                     Height="30"
                     Margin="0,5,0,15"/>

            <TextBlock Text="Mod Path"/>

            <TextBox x:Name="ModPathTextBox"
                     Height="30"
                     Margin="0,5,0,15"/>

            <TextBlock Text="Output Path"/>

            <TextBox x:Name="OutputPathTextBox"
                     Height="30"
                     Margin="0,5,0,20"/>

            <WrapPanel Margin="0,0,0,20">

                <Button x:Name="RunParserButton"
                        Content="Run Parser"
                        Width="160"
                        Height="40"
                        Margin="0,0,10,0"
                        Click="RunParserButton_Click"/>

                <Button x:Name="RunGeneratorButton"
                        Content="Run Generator"
                        Width="160"
                        Height="40"
                        Margin="0,0,10,0"
                        Click="RunGeneratorButton_Click"/>

                <Button x:Name="RunPipelineButton"
                        Content="Run Full Pipeline"
                        Width="180"
                        Height="40"
                        Margin="0,0,10,0"
                        Click="RunPipelineButton_Click"/>

                <Button x:Name="ClearOutputButton"
                        Content="Clear Output"
                        Width="140"
                        Height="40"
                        Click="ClearOutputButton_Click"/>

            </WrapPanel>

            <GroupBox Header="Output">

                <Grid>

                    <TextBox x:Name="OutputTextBox"
                             Height="500"
                             IsReadOnly="True"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             FontFamily="Consolas"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto"/>

                </Grid>

            </GroupBox>

        </StackPanel>

    </ScrollViewer>

</UserControl>