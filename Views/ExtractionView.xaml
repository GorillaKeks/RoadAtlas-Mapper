<UserControl x:Class="RoadAtlas.Mapper.Views.ExtractionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

	<ScrollViewer VerticalScrollBarVisibility="Auto">

		<Grid Margin="10">

			<Grid.RowDefinitions>
				<RowDefinition Height="Auto"/>
				<RowDefinition Height="Auto"/>
				<RowDefinition Height="Auto"/>
				<RowDefinition Height="Auto"/>
				<RowDefinition Height="Auto"/>
				<RowDefinition Height="*"/>
			</Grid.RowDefinitions>

			<!-- Header -->

			<TextBlock Grid.Row="0"
                       Text="Extraction"
                       Style="{StaticResource PageTitleStyle}"
                       Margin="0,0,0,20"/>

			<!-- Game + Status -->

			<Grid Grid.Row="1"
                  Margin="0,0,0,12">

				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="1*"/>
					<ColumnDefinition Width="1*"/>
				</Grid.ColumnDefinitions>

				<Border Grid.Column="0"
                        Style="{StaticResource CardStyle}"
                        Margin="0,0,12,0">

					<StackPanel>

						<TextBlock Text="Game Selection"
                                   Style="{StaticResource SectionTitleStyle}"
                                   Margin="0,0,0,15"/>

						<ComboBox x:Name="GameComboBox"
                                  SelectedIndex="0"
                                  SelectionChanged="GameComboBox_SelectionChanged">

							<ComboBoxItem Content="Euro Truck Simulator 2"/>
							<ComboBoxItem Content="American Truck Simulator"/>

						</ComboBox>

					</StackPanel>

				</Border>

				<Border Grid.Column="1"
                        Style="{StaticResource CardStyle}">

					<StackPanel>

						<TextBlock Text="Pipeline Status"
                                   Style="{StaticResource SectionTitleStyle}"
                                   Margin="0,0,0,15"/>

						<TextBlock Text="Pipeline"/>
						<TextBlock x:Name="PipelineStatusText"
                                   Text="Ready"
                                   Margin="0,0,0,10"/>

						<TextBlock Text="Parser"/>
						<TextBlock x:Name="ParserStatusText"
                                   Text="Idle"
                                   Margin="0,0,0,10"/>

						<TextBlock Text="Generator"/>
						<TextBlock x:Name="GeneratorStatusText"
                                   Text="Idle"/>

					</StackPanel>

				</Border>

			</Grid>

			<!-- Paths -->

			<Border Grid.Row="2"
                    Style="{StaticResource CardStyle}"
                    Margin="0,0,0,12">

				<StackPanel>

					<TextBlock Text="Paths"
                               Style="{StaticResource SectionTitleStyle}"
                               Margin="0,0,0,15"/>

					<Grid>

						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="140"/>
							<ColumnDefinition Width="*"/>
							<ColumnDefinition Width="120"/>
						</Grid.ColumnDefinitions>

						<Grid.RowDefinitions>
							<RowDefinition Height="Auto"/>
							<RowDefinition Height="Auto"/>
							<RowDefinition Height="Auto"/>
						</Grid.RowDefinitions>

						<TextBlock Text="Game Path"
                                   VerticalAlignment="Center"/>

						<TextBox x:Name="GamePathTextBox"
                                 Grid.Column="1"
                                 Height="36"
                                 Margin="0,0,10,0"/>

						<Button x:Name="BrowseGamePathButton"
                                Grid.Column="2"
                                Content="Browse..."
                                Style="{StaticResource PrimaryButtonStyle}"/>

						<TextBlock Grid.Row="1"
                                   Text="Mod Path"
                                   Margin="0,12,0,0"
                                   VerticalAlignment="Center"/>

						<TextBox x:Name="ModPathTextBox"
                                 Grid.Row="1"
                                 Grid.Column="1"
                                 Height="36"
                                 Margin="0,12,10,0"/>

						<Button x:Name="BrowseModPathButton"
                                Grid.Row="1"
                                Grid.Column="2"
                                Margin="0,12,0,0"
                                Content="Browse..."
                                Style="{StaticResource PrimaryButtonStyle}"/>

						<TextBlock Grid.Row="2"
                                   Text="Output Path"
                                   Margin="0,12,0,0"
                                   VerticalAlignment="Center"/>

						<TextBox x:Name="OutputPathTextBox"
                                 Grid.Row="2"
                                 Grid.Column="1"
                                 Height="36"
                                 Margin="0,12,10,0"/>

						<Button x:Name="BrowseOutputPathButton"
                                Grid.Row="2"
                                Grid.Column="2"
                                Margin="0,12,0,0"
                                Content="Browse..."
                                Style="{StaticResource PrimaryButtonStyle}"/>

					</Grid>

				</StackPanel>

			</Border>

			<!-- DLCs + Mods -->

			<Grid Grid.Row="3"
                  Margin="0,0,0,12">

				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="1*"/>
					<ColumnDefinition Width="1*"/>
				</Grid.ColumnDefinitions>

				<Border Grid.Column="0"
                        Style="{StaticResource CardStyle}"
                        Margin="0,0,12,0">

					<StackPanel>

						<TextBlock Text="Detected DLCs"
                                   Style="{StaticResource SectionTitleStyle}"
                                   Margin="0,0,0,15"/>

						<ListBox x:Name="DetectedDlcsListBox"
                                 Height="120"/>

					</StackPanel>

				</Border>

				<Border Grid.Column="1"
                        Style="{StaticResource CardStyle}">

					<StackPanel>

						<TextBlock Text="Detected Mods"
                                   Style="{StaticResource SectionTitleStyle}"
                                   Margin="0,0,0,15"/>

						<ListBox x:Name="DetectedModsListBox"
                                 Height="120"/>

					</StackPanel>

				</Border>

			</Grid>

			<!-- Statistics + Actions -->

			<Grid Grid.Row="4"
                  Margin="0,0,0,12">

				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="1*"/>
					<ColumnDefinition Width="1*"/>
				</Grid.ColumnDefinitions>

				<Border Grid.Column="0"
                        Style="{StaticResource CardStyle}"
                        Margin="0,0,12,0">

					<StackPanel>

						<TextBlock Text="Statistics"
                                   Style="{StaticResource SectionTitleStyle}"
                                   Margin="0,0,0,15"/>

						<TextBlock Text="Roads"/>
						<TextBlock x:Name="RoadsTextBlock"
                                   Text="-"
                                   Margin="0,0,0,10"/>

						<TextBlock Text="Cities"/>
						<TextBlock x:Name="CitiesTextBlock"
                                   Text="-"
                                   Margin="0,0,0,10"/>

						<TextBlock Text="Companies"/>
						<TextBlock x:Name="CompaniesTextBlock"
                                   Text="-"
                                   Margin="0,0,0,10"/>

						<TextBlock Text="Prefabs"/>
						<TextBlock x:Name="PrefabsTextBlock"
                                   Text="-"/>

					</StackPanel>

				</Border>

				<Border Grid.Column="1"
                        Style="{StaticResource CardStyle}">

					<StackPanel>

						<TextBlock Text="Actions"
                                   Style="{StaticResource SectionTitleStyle}"
                                   Margin="0,0,0,15"/>

						<Button x:Name="RunParserButton"
                                Content="Run Parser"
                                Margin="0,0,0,10"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Click="RunParserButton_Click"/>

						<Button x:Name="RunGeneratorButton"
                                Content="Run Generator"
                                Margin="0,0,0,10"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Click="RunGeneratorButton_Click"/>

						<Button x:Name="RunPipelineButton"
                                Content="Run Full Pipeline"
                                Margin="0,0,0,10"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Click="RunPipelineButton_Click"/>

						<Button x:Name="ClearOutputButton"
                                Content="Clear Output"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Click="ClearOutputButton_Click"/>

					</StackPanel>

				</Border>

			</Grid>

			<!-- Progress + Log -->

			<Border Grid.Row="5"
                    Style="{StaticResource CardStyle}">

				<Grid>

					<Grid.RowDefinitions>
						<RowDefinition Height="Auto"/>
						<RowDefinition Height="Auto"/>
						<RowDefinition Height="*"/>
					</Grid.RowDefinitions>

					<TextBlock Text="Progress"
                               Style="{StaticResource SectionTitleStyle}"
                               Margin="0,0,0,10"/>

					<ProgressBar x:Name="PipelineProgressBar"
                                 Grid.Row="1"
                                 Height="20"
                                 Margin="0,0,0,15"/>

					<TextBox x:Name="OutputTextBox"
                             Grid.Row="2"
                             IsReadOnly="True"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             FontFamily="Consolas"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto"/>

				</Grid>

			</Border>

		</Grid>

	</ScrollViewer>

</UserControl>