<UserControl x:Class="RoadAtlas.Mapper.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

	<ScrollViewer VerticalScrollBarVisibility="Auto">

		<Grid Margin="10">

			<Grid.RowDefinitions>
				<RowDefinition Height="Auto"/>
				<RowDefinition Height="Auto"/>
				<RowDefinition Height="Auto"/>
				<RowDefinition Height="Auto"/>
				<RowDefinition Height="Auto"/>
			</Grid.RowDefinitions>

			<!-- Header -->

			<TextBlock Grid.Row="0"
                       Text="Settings"
                       Style="{StaticResource PageTitleStyle}"
                       Margin="0,0,0,20"/>

			<!-- General -->

			<Border Grid.Row="1"
                    Style="{StaticResource CardStyle}"
                    Margin="0,0,0,12">

				<StackPanel>

					<TextBlock Text="General"
                               Style="{StaticResource SectionTitleStyle}"
                               Margin="0,0,0,15"/>

					<TextBlock Text="Repository Path"/>

					<Grid Margin="0,5,0,15">

						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="*"/>
							<ColumnDefinition Width="120"/>
						</Grid.ColumnDefinitions>

						<TextBox x:Name="RepositoryPathTextBox"
                                 Height="36"
                                 Margin="0,0,10,0"/>

						<Button Grid.Column="1"
                                Content="Browse..."
                                Style="{StaticResource PrimaryButtonStyle}"/>

					</Grid>

					<TextBlock Text="WSL Distribution"/>

					<ComboBox x:Name="WslDistributionComboBox"
                              Height="36"
                              Margin="0,5,0,0"/>

				</StackPanel>

			</Border>

			<!-- ETS2 -->

			<Border Grid.Row="2"
                    Style="{StaticResource CardStyle}"
                    Margin="0,0,0,12">

				<StackPanel>

					<TextBlock Text="ETS2 Configuration"
                               Style="{StaticResource SectionTitleStyle}"
                               Margin="0,0,0,15"/>

					<TextBlock Text="ETS2 Installation Path"/>

					<Grid Margin="0,5,0,12">

						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="*"/>
							<ColumnDefinition Width="120"/>
						</Grid.ColumnDefinitions>

						<TextBox x:Name="ETS2PathTextBox"
                                 Height="36"
                                 Margin="0,0,10,0"/>

						<Button Grid.Column="1"
                                Content="Browse..."
                                Style="{StaticResource PrimaryButtonStyle}"/>

					</Grid>

					<TextBlock Text="ETS2 Mod Folder"/>

					<Grid Margin="0,5,0,0">

						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="*"/>
							<ColumnDefinition Width="120"/>
						</Grid.ColumnDefinitions>

						<TextBox x:Name="ETS2ModPathTextBox"
                                 Height="36"
                                 Margin="0,0,10,0"/>

						<Button Grid.Column="1"
                                Content="Browse..."
                                Style="{StaticResource PrimaryButtonStyle}"/>

					</Grid>

				</StackPanel>

			</Border>

			<!-- ATS -->

			<Border Grid.Row="3"
                    Style="{StaticResource CardStyle}"
                    Margin="0,0,0,12">

				<StackPanel>

					<TextBlock Text="ATS Configuration"
                               Style="{StaticResource SectionTitleStyle}"
                               Margin="0,0,0,15"/>

					<TextBlock Text="ATS Installation Path"/>

					<Grid Margin="0,5,0,12">

						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="*"/>
							<ColumnDefinition Width="120"/>
						</Grid.ColumnDefinitions>

						<TextBox x:Name="ATSPathTextBox"
                                 Height="36"
                                 Margin="0,0,10,0"/>

						<Button Grid.Column="1"
                                Content="Browse..."
                                Style="{StaticResource PrimaryButtonStyle}"/>

					</Grid>

					<TextBlock Text="ATS Mod Folder"/>

					<Grid Margin="0,5,0,0">

						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="*"/>
							<ColumnDefinition Width="120"/>
						</Grid.ColumnDefinitions>

						<TextBox x:Name="ATSModPathTextBox"
                                 Height="36"
                                 Margin="0,0,10,0"/>

						<Button Grid.Column="1"
                                Content="Browse..."
                                Style="{StaticResource PrimaryButtonStyle}"/>

					</Grid>

				</StackPanel>

			</Border>

			<!-- Output + Actions -->

			<Border Grid.Row="4"
                    Style="{StaticResource CardStyle}">

				<StackPanel>

					<TextBlock Text="Output Configuration"
                               Style="{StaticResource SectionTitleStyle}"
                               Margin="0,0,0,15"/>

					<TextBlock Text="Output Folder"/>

					<Grid Margin="0,5,0,20">

						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="*"/>
							<ColumnDefinition Width="120"/>
						</Grid.ColumnDefinitions>

						<TextBox x:Name="OutputPathTextBox"
                                 Height="36"
                                 Margin="0,0,10,0"/>

						<Button Grid.Column="1"
                                Content="Browse..."
                                Style="{StaticResource PrimaryButtonStyle}"/>

					</Grid>

					<TextBlock Text="Actions"
                               Style="{StaticResource SectionTitleStyle}"
                               Margin="0,0,0,15"/>

					<WrapPanel>

						<Button Content="Save Settings"
                                Width="180"
                                Margin="0,0,10,0"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Click="SaveSettings_Click"/>

						<Button Content="Reload Settings"
                                Width="180"
                                Margin="0,0,10,0"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Click="ReloadSettings_Click"/>

						<Button x:Name="AutoDetectButton"
                                Content="Auto Detect Paths"
                                Width="200"
                                Style="{StaticResource PrimaryButtonStyle}"/>

					</WrapPanel>

				</StackPanel>

			</Border>

		</Grid>

	</ScrollViewer>

</UserControl>