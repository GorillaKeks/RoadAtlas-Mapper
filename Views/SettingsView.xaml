<UserControl x:Class="RoadAtlas.Mapper.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer VerticalScrollBarVisibility="Auto">

        <StackPanel Margin="10">

            <TextBlock Text="Settings"
                       FontSize="28"
                       FontWeight="Bold"/>

            <Separator Margin="0,10"/>

            <TextBlock Text="ETS2 Installation Path"/>
            <TextBox x:Name="ETS2PathTextBox"
                     Height="30"
                     Margin="0,5"/>

            <TextBlock Text="ATS Installation Path"/>
            <TextBox x:Name="ATSPathTextBox"
                     Height="30"
                     Margin="0,5"/>

            <TextBlock Text="ETS2 Mod Folder"/>
            <TextBox x:Name="ETS2ModPathTextBox"
                     Height="30"
                     Margin="0,5"/>

            <TextBlock Text="ATS Mod Folder"/>
            <TextBox x:Name="ATSModPathTextBox"
                     Height="30"
                     Margin="0,5"/>

            <TextBlock Text="Output Folder"/>
            <TextBox x:Name="OutputPathTextBox"
                     Height="30"
                     Margin="0,5"/>

            <TextBlock Text="WSL Distribution"/>
            <ComboBox x:Name="WslDistributionComboBox"
                      Height="30"
                      Margin="0,5"/>

            <StackPanel Orientation="Horizontal"
                        Margin="0,20,0,0">

                <Button Content="Save Settings"
                        Width="150"
                        Height="35"
                        Margin="0,0,10,0"
                        Click="SaveSettings_Click"/>

                <Button Content="Reload Settings"
                        Width="150"
                        Height="35"
                        Click="ReloadSettings_Click"/>

            </StackPanel>

        </StackPanel>

    </ScrollViewer>

</UserControl>